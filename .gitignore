# OS / editor
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Secrets (never commit)
.env
*.key
*.pem
*secret*

# Data / outputs
results/**
plots/**
# Keep data/ local-only by default, but allow the README and web fixtures to be tracked
data/**
!data/.gitignore
!data/README.md
!data/web/**

# Python/Node
node_modules/
__pycache__/
*.pyc
.venv/

# Logs
*.log
