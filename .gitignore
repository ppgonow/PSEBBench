# OS / editor
.DS_Store
*.swp
*.swo
.vscode/
.idea/

# Secrets (never commit)
.env
*.key
*.pem
*secret*

# Data / outputs
results/*
!results/EXPERIMENT_LOG.md
!results/STAGE_SUMMARY*.md
plots/**
build/**
# Keep data/ local-only by default, but allow the README and web fixtures to be tracked
data/**
!data/.gitignore
!data/README.md
!data/web/**

# Python/Node
node_modules/
__pycache__/
*.pyc
.venv/
**/__pycache__/

# Repo-local generated / vendor / temp
presentation/node_modules/
presentation/_extracted/
agent_replica/.openclaw/
agent_replica/.git/

# Logs
*.log
results/server_8080.log
